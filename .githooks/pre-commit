#!/usr/bin/env bash
set -euo pipefail

# Operate only on staged files
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)
[[ -z "$staged_files" ]] && exit 0

while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  [[ ! -f "$file" ]] && continue

  # Skip binary files
  if git diff --cached --numstat -- "$file" | awk '{print $1,$2}' | grep -q '^- -$'; then
    continue
  fi

  # Remove trailing whitespace and normalize final newline
  perl -i -pe 's/[ \t]+$//; END { print "\n" unless /\n\z/ }' "$file"

  git add -- "$file"
done <<< "$staged_files"

# Verify no whitespace errors in staged diff
check_out="$(git diff --cached --check || true)"
if [[ -n "$check_out" ]]; then
  echo "pre-commit hook: whitespace errors remain in staged changes." >&2
  printf '%s\n' "$check_out" >&2
  exit 1
fi

python3 .githooks/public-safety-check.py

exit 0
